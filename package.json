{
    "name": "dayone-to-md",
    "version": "0.0.3",
    "description": "Convert the DayOne JSON export to markdown files.",
    "bin": "bin/index.js",
    "scripts": {
        "build": "babel --out-dir bin --ignore *.test.js src",
        "format": "prettier --trailing-comma es5 --no-semi --single-quote --write 'src/**/*.{js,json}'",
        "test": "jest"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/danseethaler/dayone-to-md.git"
    },
    "keywords": [
        "dayone",
        "journaling",
        "json"
    ],
    "author": "Dan Seethaler <dan@seethalers.com> (https://danseethaler.com/)",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/danseethaler/dayone-to-md/issues"
    },
    "homepage": "https://github.com/danseethaler/dayone-to-md#readme",
    "devDependencies": {
        "eslint": "^10.0.3",
        "eslint-plugin-node": "^11.1.0",
        "jest": "^30.2.0",
        "prettier": "^3.8.1"
    },
    "dependencies": {
        "adm-zip": "^0.4.7",
        "date-fns": "^1.28.5",
        "mkdirp": "^0.5.1",
        "moment": "^2.19.2",
        "sanitize-filename": "^1.6.1"
    },
    "engines": {
        "node": ">=6.0.0"
    }
}
